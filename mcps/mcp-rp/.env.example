# ReportPortal Connection
RP_URL=https://reportportal.example.com
RP_TOKEN=your-api-token-here
RP_PROJECT=my_project

# Alternative: OAuth authentication (used if RP_TOKEN is not set)
# RP_USERNAME=your-username
# RP_PASSWORD=your-password

# SSL verification (set to false for self-signed certs)
# RP_VERIFY_SSL=true
